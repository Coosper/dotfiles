// -*- mode: jsonc -*-
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
//            COOSPER'S WAYBAR          //
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
{
  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
  //               SECTION: GLOBAL         //
  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //	
	"layer": "top",            // Waybar at top layer
	"position": "top",      // Waybar position (top|bottom|left|right)
	"height": 40,                 // Waybar height (remove for auto)
	"width": 1920,             // Waybar width
	"spacing": 4,                 // Gaps between modules (px)

  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
  //       SECTION: LAYOUT & ORDER         //
  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
  "modules-left": [
    "hyprland/workspaces", 
    "custom/cava",
  ],
  "modules-center": [
	"clock",
	],
  "modules-right": [
    "tray",
    "pulseaudio",
    "battery",
    "custom/power"
  ],

  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
  //       SECTION: SWAY INTEGRATIONS      //
  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //

	"hyprland/workspaces": {
	  "disable-scroll": true,
 	 "warp-on-scroll": false,
 	 "all-outputs": true,
 	 "active-only": false,
 	 "persistent-workspaces": {
   	 "*": [1, 2, 3, 4, 5]
 	 },
 	 "format": "{icon}",
 	 "format-icons": {
   	 "active.": "п†’",
   	 "default": "п„‘"
 	 },
 	 "workspaces": [1, 2, 3, 4, 5],
        	"sort-by-number": true
	},


  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
  //       SECTION: MEDIA & AUDIO          //
  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //

"pulseaudio": {
  "scroll-step": 2,
  "format": "{icon}  {volume}%",
  "format-muted": "muted",
  "tooltip": false,
  "max-volume": 100,
  "on-click": "pavucontrol",
  "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
  "on-click-middle": "pactl set-sink-volume @DEFAULT_SINK@ 100%",
  "format-icons": ["пЂ¦", "пЂ§", "пЂЁ"]
},

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon} {capacity}%",
    "format-full": "{icon} {capacity}%",
    "format-charging": "п‡¦ {capacity}%",
    "format-alt": "{time} {icon}",
    "format-icons": ["п‰„", "п‰ѓ", "п‰‚", "п‰Ѓ", "п‰Ђ"]
  },

  "custom/power": {
    "format": "вЏ»",
    "tooltip": false,
    "menu": "on-click",
    "menu-file": "$HOME/.config/waybar/power_menu.xml", // See resources folder
    "menu-actions": {
      "shutdown": "shutdown",
      "reboot": "reboot",
      "suspend": "systemctl suspend",
      "hibernate": "systemctl hibernate"
    }
  },

  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
  //        SECTION: TIME & CALENDAR       //
  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //

	"clock": {
	  "timezone": "Europe/Dublin",
 	  "format": "пЂ— {:%H:%M п„і :%d %b %Y}",        // Example: пЂ— 16:45 п„і 21 Sep 2025
	  "format-alt": "{:%Y-%m-%d}",                 // Example: 2025-09-21
 	  "tooltip-format": "<big>{:%A, %d %B %Y}</big>\n<tt><small>{calendar}</small></tt>"
	},


  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //
  //           SECTION: MISC / UI          //
  // в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ //

  "tray": {
	"icon-size": 21,
	"spacing": 10,
	"icons": {
	"blueman": "bluetooth",
	"TelegramDesktop": "$HOME/.local/share/icons/hicolor/16x16/apps/telegram.png"
	 }
	},

"custom/playerinfo": {
            "format": "&lt; {} &gt;",
            "exec": "~/.config/waybar/modules/playerinfo.sh",
            "escape": true,
            "return-type": "json",
            "interval": 1,
            "tooltip": true,
            "on-click-middle": "playerctl play-pause",
            "on-click-right": "playerctl next",
            "on-click-left": "playerctl previous"
        },

"custom/cava": {
	"format": "{}",
	"exec": "~/.config/waybar/modules/cava.sh",
	},


}
